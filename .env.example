# Neon Auth + Neon Data API

# Required.
# Used to sign app auth/session cookies.
# Generate with Node:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=

# Required.
# Keep this different from AUTH_SECRET when possible.
# Generate with Node:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
NEON_AUTH_COOKIE_SECRET=

# Required.
# From Neon dashboard -> Auth.
# Example:
# https://your-project.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_BASE_URL=

# Required if you use the Neon Data API for reports.
# From Neon dashboard -> Data API for your branch.
NEON_DATA_API_URL=

# Optional but useful for server-side fallback access to the Neon Data API.
# Use a Neon API key token from the Neon dashboard API keys section.
# If omitted, the app will rely on the signed-in Neon Auth access token.
NEON_DATA_API_KEY=
