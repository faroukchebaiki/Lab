# Required for login sessions.
# Use a long random value, for example:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Required login credentials for the app.
# These are the username and password you will type on the login page.
APP_USERNAME=admin
APP_PASSWORD=lab2026

# Recommended for Vercel production:
# connect a Postgres database from the Vercel Marketplace
# and paste the connection string here.
# Example:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# How this app uses these variables:
# AUTH_SECRET   -> signs the secure session cookie
# APP_USERNAME  -> allowed login username
# APP_PASSWORD  -> allowed login password
# DATABASE_URL  -> stores reports permanently in Postgres
#
# If DATABASE_URL is empty locally, the app falls back to:
# data/flash-journal-records.json
#
# On Vercel, add all 4 variables in:
# Project Settings -> Environment Variables
