# Neon Auth + Neon Data API

# Required secret.
# Used to sign the app auth/session cookies.
# Generate with:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Optional extra cookie secret for Neon Auth.
# If left empty, the app will use AUTH_SECRET.
NEON_AUTH_COOKIE_SECRET=

# Required.
# From your Neon dashboard -> Auth.
# Example:
# https://your-project.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_BASE_URL=

# Required.
# Neon Data API base URL for your project.
# Add the HTTP endpoint Neon gives you for the PostgREST-compatible Data API.
NEON_DATA_API_URL=

# Optional secret.
# Only add this if you want server-side access to the Data API without relying on the signed-in Neon Auth token.
NEON_DATA_API_KEY=
